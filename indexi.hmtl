<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8" />
    <title>Conversor de Moedas - API</title>
    <link rel="stylesheet" href="style.css" />
</head>
<body>
    <div class="container">
        <h1>Conversor de Moedas</h1>

        <div class="converter">
            <div class="input-group">
                <label>Valor</label>
                <input type="number" id="valor" placeholder="Digite o valor" />
            </div>

            <div class="select-group">
                <label>De:</label>
                <select id="moedaOrigem"></select>

                <label>Para:</label>
                <select id="moedaDestino"></select>
            </div>

            <h2 id="resultado">Resultado aparecerá aqui...</h2>
        </div>
    </div>

    <script src="script.js"></script>
</body>
</html>
